<odoo>
    <data>
        <record id="view_fts_mqtt_user_tree" model="ir.ui.view">
            <field name="name">fts.mqtt.user.tree</field>
            <field name="model">fts.mqtt.user</field>
            <field name="arch" type="xml">
                <list string="MQTT User" editable="bottom">
                    <field name="name"/>
                    <field name="password"/>
                    <field name="broker_id"/>
                    <field name="partner_id"/>
                    <field name="status" widget="badge" decoration-success="status == 'active'" decoration-muted="status == 'pause'"/>
                </list>
            </field>
        </record>

        <record id="view_fts_mqtt_user_search" model="ir.ui.view">
            <field name="name">fts.mqtt.user.search</field>
            <field name="model">fts.mqtt.user</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="broker_id"/>
                    <filter string="激活" name="active" domain="[('status', '=', 'active')]"/>
                    <filter string="停用" name="pause" domain="[('status', '=', 'pause')]"/>
                    <group>
                        <filter string="状态" name="status" context="{'group_by': 'status'}"/>
                        <filter string="MQTT Broker" name="broker" context="{'group_by': 'broker_id'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo>
