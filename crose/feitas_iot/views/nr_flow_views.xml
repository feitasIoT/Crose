<odoo>
    <data>

        <!-- 搜索视图 -->
        <record id="view_fts_nr_flow_search" model="ir.ui.view">
            <field name="name">fts.nr.flow.search</field>
            <field name="model">fts.nr.flow</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="tag_ids"/>
                    <group>
                        <filter string="实例" name="group_by_instance" context="{'group_by': 'instance_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- 看板视图 -->
        <record id="view_fts_nr_flow_kanban" model="ir.ui.view">
            <field name="name">fts.nr.flow.kanban</field>
            <field name="model">fts.nr.flow</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <field name="name"/>
                    <field name="tag_ids"/>
                    <field name="heat"/>
                    <templates>
                        <t t-name="card">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <span class="badge text-bg-warning" t-if="record.heat.raw_value">
                                    <i class="fa fa-fire me-1"/> <field name="heat"/>
                                </span>
                            </div>
                            <div class="mb-2">
                                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            </div>
                            <div class="o_kanban_record_bottom mt-auto">
                                <div class="oe_kanban_bottom_left">
                                    <field name="instance_id"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="activity_ids" widget="kanban_activity"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_fts_nr_flow_tree" model="ir.ui.view">
            <field name="name">fts.nr.flow.tree</field>
            <field name="model">fts.nr.flow</field>
            <field name="arch" type="xml">
                <list string="Node-RED Flow">
                    <field name="name"/>
                    <field name="instance_id"/>
                    <field name="nr_id"/>
                    <field name="type"/>
                    <button name="action_view_nodes" type="object" icon="fa-sitemap" title="节点"/>
                </list>
            </field>
        </record>

        <record id="view_fts_nr_flow_form" model="ir.ui.view">
            <field name="name">fts.nr.flow.form</field>
            <field name="model">fts.nr.flow</field>
            <field name="arch" type="xml">
                <form string="Node-RED Flow">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="instance_id"/>
                                <field name="nr_id"/>
                            </group>
                            <group>
                                <field name="type"/>
                                <field name="is_template"/>
                                <field name="data_model_id"/>
                            </group>
                            <group>
                                <field name="tag_ids" widget="many2many_tags"/>
                                <field name="heat"/>
                                
                            </group>
                            
                        </group>
                        <notebook>
                            <page string="说明">
                                <field name="description" widget="html" nolabel="1"/>
                            </page>
                            <page string="提示词">
                                <field name="prompt" nolabel="1"/>
                            </page>
                            
                            <page string="内容">
                                <field name="content" widget="code" options="{'mode': 'javascript'}" nolabel="1"/>
                            </page>
                            <page string="参数">
                                <field name="param_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="value"/>
                                        <field name="type"/>
                                        <field name="description"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter>
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </chatter>
                </form>
            </field>
        </record>

    </data>
</odoo>

