<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fts_knowledge_tree" model="ir.ui.view">
        <field name="name">fts.knowledge.tree</field>
        <field name="model">fts.knowledge</field>
        <field name="arch" type="xml">
            <list string="Knowledge Base">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_fts_knowledge_form" model="ir.ui.view">
        <field name="name">fts.knowledge.form</field>
        <field name="model">fts.knowledge</field>
        <field name="arch" type="xml">
            <form string="Knowledge Base">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="json_source" widget="code" options="{'mode': 'javascript'}"/>
                        
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fts_knowledge" model="ir.actions.act_window">
        <field name="name">Knowledge Base</field>
        <field name="res_model">fts.knowledge</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
