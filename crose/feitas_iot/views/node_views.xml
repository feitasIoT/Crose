<odoo>
    <data>

        <record id="view_fts_nr_node_tree" model="ir.ui.view">
            <field name="name">fts.nr.node.tree</field>
            <field name="model">fts.nr.node</field>
            <field name="arch" type="xml">
                <list string="节点">
                    <field name="name"/>
                    <field name="instance_id"/>
                    <field name="flow_id"/>
                    <field name="nr_id"/>
                    <field name="node_type"/>
                </list>
            </field>
        </record>

        <record id="view_fts_nr_node_form" model="ir.ui.view">
            <field name="name">fts.nr.node.form</field>
            <field name="model">fts.nr.node</field>
            <field name="arch" type="xml">
                <form string="节点">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="node_type"/>
                                <field name="config_node_ids" widget="many2many_tags"/>
                            </group>
                            <group>
                                <field name="instance_id" readonly="1"/>
                                <field name="flow_id"/>
                                <field name="nr_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="内容">
                                <field name="content" widget="code" options="{'mode': 'javascript'}" nolabel="1"/>
                            </page>

                            <page string="配置">
                                <field name="item_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="key"/>
                                        <field name="value_type"/>
                                        <field name="value"/>
                                        <field name="note"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
