<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_fts_mqtt_topic_tree" model="ir.ui.view">
            <field name="name">fts.mqtt.topic.tree</field>
            <field name="model">fts.mqtt.topic</field>
            <field name="arch" type="xml">
                <list string="MQTT Topics">
                    <field name="name"/>
                    <field name="broker_id"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_fts_mqtt_topic_form" model="ir.ui.view">
            <field name="name">fts.mqtt.topic.form</field>
            <field name="model">fts.mqtt.topic</field>
            <field name="arch" type="xml">
                <form string="MQTT Topic">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="broker_id"/>
                            <field name="partner_ids" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_fts_mqtt_topic" model="ir.actions.act_window">
            <field name="name">MQTT Topics</field>
            <field name="res_model">fts.mqtt.topic</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Server Action to Sync Topics -->
        <record id="action_sync_mqtt_topics" model="ir.actions.server">
            <field name="name">同步 MQTT 主题</field>
            <field name="model_id" ref="model_fts_mqtt_topic"/>
            <field name="binding_model_id" ref="model_fts_mqtt_topic"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">
                action = env['fts.mqtt.topic'].action_sync_all()
            </field>
        </record>


    </data>
</odoo>
