<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_crose_component_tree" model="ir.ui.view">
            <field name="name">crose.component.tree</field>
            <field name="model">crose.component</field>
            <field name="arch" type="xml">
                <list string="系统组件">
                    <field name="name"/>
                    <field name="component_type"/>
                    <field name="host"/>
                    <field name="port"/>
                    <field name="status" widget="badge" decoration-success="status == 'online'" decoration-danger="status == 'error'" decoration-muted="status == 'offline'"/>
                    <field name="error_reason" optional="show" invisible="status == 'online'"/>
                    <field name="last_check_time"/>
                </list>
            </field>
        </record>

        <record id="view_crose_component_form" model="ir.ui.view">
            <field name="name">crose.component.form</field>
            <field name="model">crose.component</field>
            <field name="arch" type="xml">
                <form string="系统组件">
                    <header>
                        <button name="action_check_status" type="object" string="检查状态" class="oe_highlight"/>
                        <button name="action_view_packages" type="object" string="查看安装包"
                                invisible="component_type != 'npm'"/>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="alert alert-danger mb-2" role="alert" invisible="status == 'online' or not error_reason">
                            <strong>检查失败:</strong> <field name="error_reason" nolabel="1"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="组件名称"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="component_type"/>
                                <field name="host"/>
                                <field name="port"/>
                                <field name="url"/>
                            </group>
                            <group>
                                <field name="last_check_time"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="元数据">
                                <field name="metadata" widget="code" options="{'mode': 'javascript'}"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_crose_component" model="ir.actions.act_window">
            <field name="name">系统组件</field>
            <field name="res_model">crose.component</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
