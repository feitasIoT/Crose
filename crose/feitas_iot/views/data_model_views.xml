<odoo>
    <data>
        <!-- Search View -->
        <record id="view_fts_data_model_search" model="ir.ui.view">
            <field name="name">fts.data.model.search</field>
            <field name="model">fts.data.model</field>
            <field name="arch" type="xml">
                <search string="Data Model">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="provider_id"/>
                    <field name="mqtt_topic_id"/>
                    <field name="nr_instance_id"/>
                    <field name="state"/>
                    <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Effective" name="state_effective" domain="[('state', '=', 'effective')]"/>
                    <group>
                        <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                        <filter string="Requester" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
                        <filter string="Instance" name="group_by_instance" context="{'group_by': 'nr_instance_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_fts_data_model_form" model="ir.ui.view">
            <field name="name">fts.data.model.form</field>
            <field name="model">fts.data.model</field>
            <field name="arch" type="xml">
                <form string="Data Model">
                    <header>
                        <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(feitas_iot.action_fts_data_address)d" type="action" class="oe_stat_button" icon="fa-sitemap">
                                <field name="address_ids" widget="statinfo" string="地址"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="partner_id"/>
                                <field name="provider_id"/>
                                <field name="mqtt_topic_id"/>
                                <field name="nr_instance_id"/>
                                <field name="description"/>
                            </group>
                            <group>
                                <field name="protocol" />
                                <field name="host" />
                                <field name="tcp_port" />
                                <field name="serial_port" />
                                <field name="tcp_type" />
                                <field name="slave_id" />
                                <field name="smb_share" invisible="protocol != 'smb'" />
                                <field name="smb_username" invisible="protocol != 'smb'" />
                                <field name="smb_password" invisible="protocol != 'smb'" />
                            </group>
                        </group>
                        <notebook>
                            <page name="datas_search" string="数据查询">
                                <group>
                                    <group>
                                        <field name="query_start_time"/>
                                        <field name="query_end_time"/>
                                        <field name="query_interval"/>
                                    </group>
                                    <group>
                                        <button name="action_test_query" type="object" string="测试" class="oe_highlight"/>
                                        <button name="action_open_spreadsheet" type="object" string="电子表格" class="oe_highlight"/>
                                    </group>
                                </group>
                            </page>
                            <page name="datas" string="数据结构">
                                <field name="data_structure" widget="code" options="{'mode': 'javascript'}" nolabel="1" colspan="2"/>
                            </page>
                            <page name="application" string="应用">
                                <group style="margin-bottom: 10px !important">
                                    <field name="nr_flow_ids" widget="many2many_tags" style="margin-bottom: 10px !important"/>
                                    <field name="app_param_ids" nolabel="1" colspan="4">
                                        <list editable="bottom">
                                            <field name="name"/>
                                            <field name="value"/>
                                            <field name="type"/>
                                            <field name="description"/>
                                        </list>
                                    </field>
                                </group>

                                <group string="日志">
                                    <field name="log_ids" nolabel="1" colspan="4">
                                        <list>

                                            <field name="value"/>

                                        </list>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                            
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_fts_data_model_tree" model="ir.ui.view">
            <field name="name">fts.data.model.tree</field>
            <field name="model">fts.data.model</field>
            <field name="arch" type="xml">
                <list string="Data Model">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="provider_id"/>
                    <field name="mqtt_topic_id"/>
                    <field name="nr_instance_id"/>
                    <field name="state" widget="badge" decoration-success="state == 'effective'" decoration-info="state == 'draft'" decoration-warning="state == 'approval'" decoration-muted="state == 'invalid'"/>
                </list>
            </field>
        </record>



    </data>
</odoo>
