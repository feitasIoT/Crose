<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="feitas_iot.OverviewDashboard">
        <div class="o_action p-4">
            <div class="mb-3">
                <h2 class="m-0">概览</h2>
            </div>
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <div class="border rounded p-3 bg-white h-100">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <h5 class="m-0">平台</h5>
                                    <i class="fa fa-question-circle text-muted" title="显示平台关键组件的运行状态，包括 MQTT Broker、Npm Registry 和本地实例的在线情况。" style="cursor: pointer;"></i>
                                </div>
                                <t t-if="state.loading">
                                    <div class="text-muted">加载中...</div>
                                </t>
                                <t t-elif="state.error">
                                    <div class="text-danger" t-esc="state.error"/>
                                </t>
                                <t t-else="">
                                    <div class="row g-3 feitas_iot_dashboard_gauges">
                                        <t t-foreach="state.components" t-as="component" t-key="component.id">
                                            <div class="col-12">
                                                <div class="feitas_iot_dashboard_gauge">
                                                    <div class="d-flex align-items-baseline justify-content-between">
                                                        <div class="fw-semibold" t-esc="component.name"/>
                                                        <div class="text-muted">
                                                            <span t-att-class="'badge text-bg-' + (component.status === 'online' ? 'success' : 'danger')" t-esc="component.status"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="border rounded p-3 bg-white h-100">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <h5 class="m-0">统计</h5>
                                    <i class="fa fa-question-circle text-muted" title="统计平台的核心资源数量，如边缘代理、应用实例和 MQTT 主题。" style="cursor: pointer;"></i>
                                </div>
                                <t t-if="state.loading">
                                    <div class="text-muted">加载中...</div>
                                </t>
                                <t t-elif="state.error">
                                    <div class="text-danger" t-esc="state.error"/>
                                </t>
                                <t t-else="">
                                    <t t-set="agentCount" t-value="(state.overview &amp;&amp; state.overview.stats &amp;&amp; state.overview.stats.agents) || 0"/>
                                    <t t-set="instanceCount" t-value="(state.overview &amp;&amp; state.overview.stats &amp;&amp; state.overview.stats.instances) || 0"/>
                                    <t t-set="topicCount" t-value="(state.overview &amp;&amp; state.overview.stats &amp;&amp; state.overview.stats.topics) || 0"/>
    
                                    <div class="d-flex gap-2 feitas_iot_dashboard_kpis">
                                        <div class="border rounded p-2 bg-light feitas_iot_dashboard_kpi">
                                            <div class="text-muted small">代理数</div>
                                            <div class="feitas_iot_dashboard_kpi_value">
                                                <t t-esc="agentCount"/>
                                            </div>
                                        </div>
                                        <div class="border rounded p-2 bg-light feitas_iot_dashboard_kpi">
                                            <div class="text-muted small">实例数</div>
                                            <div class="feitas_iot_dashboard_kpi_value">
                                                <t t-esc="instanceCount"/>
                                            </div>
                                        </div>
                                        <div class="border rounded p-2 bg-light feitas_iot_dashboard_kpi">
                                            <div class="text-muted small">主题数</div>
                                            <div class="feitas_iot_dashboard_kpi_value">
                                                <t t-esc="topicCount"/>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="d-flex flex-column gap-3">
                        <div class="border rounded p-3 bg-white">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h5 class="m-0">待办</h5>
                                <i class="fa fa-question-circle text-muted" title="这里列出需要处理的待办事项。" style="cursor: pointer;"></i>
                            </div>
                            <div class="text-muted">暂无待办</div>
                        </div>

                        <div class="border rounded p-3 bg-white">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h5 class="m-0">消息</h5>
                                <i class="fa fa-question-circle text-muted" title="这里显示系统的最新动态消息。" style="cursor: pointer;"></i>
                            </div>
                            <t t-if="state.logs and state.logs.length">
                                <div class="d-flex flex-column gap-2">
                                    <t t-foreach="state.logs" t-as="log" t-key="log.id">
                                        <div class="border rounded p-2">
                                            <div class="text-muted small">
                                                <t t-esc="formatLogCreateDate(log.create_date)"/>
                                            </div>
                                            <div>
                                                <t t-esc="log.message"/>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="text-muted">暂无动态</div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
